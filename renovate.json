{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    "group:allNonMajor"
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Expo SDK のメジャーアップデートは手動対応",
      "matchPackagePatterns": ["^expo"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "React Native のメジャーアップデートは手動対応",
      "matchPackageNames": ["react-native"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "devDependencies は自動マージ (minor/patch)",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "GitHub Actions のアップデートをグルーピング",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "automerge": true
    }
  ],
  "schedule": ["before 9am on monday"]
}
