{
  "name": "sf6-frame-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=default --reporter=github-actions",
    "build:web": "expo export --platform web",
    "build:ios": "eas build --platform ios --profile preview",
    "build:android": "eas build --platform android --profile preview",
    "build:dev": "eas build --platform ios --profile development",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/analytics": "^23.8.6",
    "@react-native-firebase/app": "^23.8.6",
    "expo": "~55.0.2",
    "expo-build-properties": "~55.0.9",
    "expo-constants": "^55.0.7",
    "expo-dev-client": "~55.0.10",
    "expo-font": "^55.0.4",
    "expo-image": "^55.0.5",
    "expo-linking": "^55.0.7",
    "expo-localization": "^55.0.8",
    "expo-router": "^55.0.2",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "^55.0.9",
    "expo-tracking-transparency": "~55.0.8",
    "i18next": "^25.8.13",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-google-mobile-ads": "^16.0.3",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.23.0",
    "react-native-web": "^0.21.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "~19.2.2",
    "@vitest/coverage-v8": "^4.0.18",
    "eas-cli": "^18.0.6",
    "eslint": "^10.0.2",
    "nativewind": "5.0.0-preview.2",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "pnpm": {
    "overrides": {
      "ajv@>=8.0.0 <8.18.0": ">=8.18.0",
      "minimatch@>=5.0.0 <5.1.7": ">=5.1.8",
      "node-forge@<1.4.0": ">=1.4.0",
      "tar@>=7.0.0 <7.5.11": ">=7.5.11",
      "diff@<8.0.3": ">=8.0.3",
      "@xmldom/xmldom@<0.8.12": ">=0.8.12",
      "brace-expansion@>=1.0.0 <1.1.13": ">=1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "brace-expansion@>=5.0.0 <5.0.5": ">=5.0.5",
      "flatted@<3.4.2": ">=3.4.2",
      "picomatch@>=2.0.0 <2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "protobufjs@<7.5.5": ">=7.5.5",
      "vite@>=7.3.0 <7.3.2": ">=7.3.2",
      "yaml@<2.8.3": ">=2.8.3"
    }
  }
}
